# =========================================
# Call Me AI environment variables
# =========================================
# Keep values empty in this template.

# -----------------------------------------
# Quick start (minimum)
# -----------------------------------------
# Required for text chat:
VITE_OPENROUTER_API_KEY=

# Required for FAL images:
VITE_FAL_API_KEY=

# Optional but useful for stable provider metadata:
VITE_PUBLIC_URL=


# -----------------------------------------
# Advanced (optional)
# -----------------------------------------

# OpenRouter (Vite/browser + shared config)
VITE_OPENROUTER_NSFW_API_KEY=
VITE_OPENAI_API_KEY=
VITE_OPENROUTER_BASE_URL=
VITE_OPENROUTER_SFW_MODEL=
VITE_OPENROUTER_MODEL=
VITE_OPENROUTER_NSFW_MODEL=
VITE_OPENROUTER_FALLBACK_MODEL=
VITE_OPENROUTER_SFW_MODEL_FALLBACK=
VITE_OPENROUTER_NSFW_MODEL_FALLBACK=
VITE_OPENROUTER_API_KEY_FALLBACK=
VITE_OPENROUTER_NSFW_API_KEY_FALLBACK=
VITE_OPENROUTER_IMAGE_MODEL=
VITE_OPENROUTER_IMAGE_MODEL_SFW=
VITE_OPENROUTER_NSFW_IMAGE_MODEL=
VITE_OPENROUTER_IMAGE_MODEL_NSFW=

# OpenRouter (server/runtime aliases)
OPENROUTER_API_KEY=
OPENROUTER_NSFW_API_KEY=
OPENAI_API_KEY=
OPENROUTER_BASE_URL=
OPENROUTER_SFW_MODEL=
OPENROUTER_MODEL=
OPENROUTER_NSFW_MODEL=
OPENROUTER_FALLBACK_MODEL=
OPENROUTER_SFW_MODEL_FALLBACK=
OPENROUTER_NSFW_MODEL_FALLBACK=
OPENROUTER_API_KEY_FALLBACK=
OPENROUTER_NSFW_API_KEY_FALLBACK=

# FAL (Vite/browser + shared config)
VITE_FAL_AI_API_KEY=
VITE_FAL_NSFW_API_KEY=
VITE_FAL_BASE_URL=
VITE_FAL_MODEL=
VITE_FAL_MODEL_SFW=
VITE_FAL_NSFW_MODEL=
VITE_FAL_MODEL_NSFW=
VITE_FAL_MODEL_FALLBACK=
VITE_FAL_NSFW_MODEL_FALLBACK=
VITE_FAL_API_KEY_FALLBACK=
VITE_FAL_NSFW_API_KEY_FALLBACK=

# FAL (server/runtime aliases)
FAL_API_KEY=
FAL_AI_API_KEY=
FAL_NSFW_API_KEY=
FAL_BASE_URL=
FAL_MODEL=
FAL_MODEL_SFW=
FAL_NSFW_MODEL=
FAL_MODEL_NSFW=
FAL_MODEL_FALLBACK=
FAL_NSFW_MODEL_FALLBACK=
FAL_API_KEY_FALLBACK=
FAL_NSFW_API_KEY_FALLBACK=

# ElevenLabs voice (optional)
VITE_ELEVENLABS_API_KEY=
ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_ID=

# App routing / metadata
VITE_IMAGE_PROVIDER=
PUBLIC_URL=
SITE_URL=
